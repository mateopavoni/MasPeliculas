# Si vas a poner contraseñas reales ahí, descomenta la siguiente línea:
# appsettings.Development.json

# Si decides usar librerías de .env (como DotNetEnv)
.env
.env.local

# Bases de datos locales (si usas SQLite)
*.db
*.sqlite

# Logs
*.log